# Copy this file to `.env` (same folder) and fill in your real values.
# `.env` itself should never be committed to git -- it's already in .gitignore.

# Leave this line commented out to keep using SQLite (zero setup, good for
# quick local testing). Uncomment and fill in to switch to PostgreSQL:
# DATABASE_URL=postgresql://endotrack_user:your_password_here@localhost:5432/endotrack

# Used to sign login tokens. Generate a real one with:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
# and paste the result below. If left unset, a clearly-labeled insecure
# development default is used instead (see backend/app/auth.py).
# ENDOTRACK_SECRET_KEY=
